{
  "name": "portfolio-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Scroll-scrubbed research journey animation for shubhamgajjar.dev",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render Main ../public/anim --image-format=png --concurrency=4",
    "build:webp": "remotion render Main ../public/anim --image-format=webp --concurrency=4",
    "build:half": "remotion render Main ../public/anim --image-format=png --concurrency=4 --scale=0.5",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.260",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.260"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
